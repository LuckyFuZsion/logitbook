# Public site URL (sitemap, OG). Optional in dev.
# NEXT_PUBLIC_SITE_URL=https://logitshop.com

# Admin sign-in (set in .env.local — never commit real secrets)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Used to sign the admin session cookie (long random string)
ADMIN_SESSION_SECRET=

# Cloudinary (optional). Easiest: paste the dashboard line (folder logit/gallery on upload).
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Or split (preferred if you see "Invalid signature" / 401): all three must match the dashboard.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME can substitute for CLOUDINARY_CLOUD_NAME only.
# Otherwise uploads stay under public/uploads/gallery/.

# Firestore CMS (optional). When Firebase Admin credentials are set, gallery + shop admin saves
# go to Firestore instead of data/*.json. Reads use Firestore first, then fall back to JSON if the doc is missing.
# Create a service account (Project settings → Service accounts), grant "Cloud Datastore User" or "Editor",
# then either paste the full JSON below or set CLIENT_EMAIL + PRIVATE_KEY.
# Deploy rules: firebase deploy --only firestore:rules (see firestore.rules in this repo — deny all client access).
#
# Never commit service account JSON files. Add *-firebase-adminsdk-*.json to .gitignore (already in this repo).
# If a private key was ever pasted into chat or committed, revoke it in GCP and create a new key.
#
# FIREBASE_PROJECT_ID=logit-50d38
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...one line...}
# Or split (private key must keep \n as the two characters backslash + n, or wrap in double quotes):
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@....iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# Or point at a JSON file on disk (local dev only; keep file out of git).
# Project ID is read from that JSON; FIREBASE_PROJECT_ID is optional here.
# GOOGLE_APPLICATION_CREDENTIALS=./your-service-account.json
# Or: FIREBASE_SERVICE_ACCOUNT_PATH=./your-service-account.json (same behavior; explicit path from project root)
# Or on GCP: FIREBASE_USE_ADC=true with metadata service account.
# Optional collection name (default: cms):
# FIRESTORE_CMS_COLLECTION=cms
# Optional top-level collection for admin audit log entries (before/after snapshots, revert flags). Default: cms_audit_log
# FIRESTORE_AUDIT_COLLECTION=cms_audit_log

# Firebase Web SDK (optional) — from Project settings → Your apps → Web app. Browser Analytics only.
# Does not replace Firebase Admin credentials for server-side Firestore CMS.
#
# If you see: [Analytics: Dynamic config fetch failed] API key not valid (400):
# - Google Cloud → APIs & Services → Credentials → open this project's Browser API key.
# - Application restrictions: add referrers http://localhost:3000/* and http://127.0.0.1:3000/* (and production), or None to test.
# - API restrictions: Don't restrict (testing) or allow Firebase / Analytics related APIs.
# - Re-copy apiKey from Firebase → Project settings → Your apps; no extra quotes in .env.local.
# Temporarily disable Analytics: NEXT_PUBLIC_FIREBASE_ANALYTICS=0
# Or disable all browser Firebase (no initializeApp): NEXT_PUBLIC_FIREBASE_WEB=0
#
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# NEXT_PUBLIC_FIREBASE_ANALYTICS=1
# NEXT_PUBLIC_FIREBASE_WEB=1